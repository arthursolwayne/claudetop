#!/usr/bin/env python3
"""Minimal process-list TUI using curses. No external dependencies."""

import curses
import json
import os
import subprocess
import time

# Thresholds for filtering noise
MIN_CPU = 0.1
MIN_RSS_KB = 1024   # 1MB
# Idle tmux shells: 0% CPU, <10MB, comm is bash/zsh/sh
TMUX_SHELL_COMMS = {"bash", "zsh", "sh"}

# Logging
LOG_DIR = "/shared/claudetop/logs"
LOG_PATH = os.path.join(LOG_DIR, "ticks.jsonl")
HISTORY_TAIL_LINES = 100


PROCSCAN = os.path.join(os.path.dirname(os.path.abspath(__file__)), "procscan")


def read_proc_stat_fields(pid):
    """Read /proc/PID/stat, returning (comm, ppid, utime, stime) or None."""
    try:
        with open(f"/proc/{pid}/stat") as f:
            raw = f.read()
        i = raw.rfind(")")
        comm = raw[raw.index("(") + 1 : i]
        fields = raw[i + 2 :].split()
        return comm, int(fields[1]), int(fields[11]), int(fields[12])
    except (FileNotFoundError, ProcessLookupError, ValueError, IndexError,
            PermissionError, OSError):
        return None


def read_rss_kb(pid):
    """Return RSS in kilobytes from /proc/PID/statm, or 0."""
    try:
        with open(f"/proc/{pid}/statm") as f:
            pages = int(f.read().split()[1])
        return pages * (os.sysconf("SC_PAGE_SIZE") // 1024)
    except (FileNotFoundError, ProcessLookupError, ValueError, IndexError,
            PermissionError, OSError):
        return 0


def fmt_mem(kb):
    if kb >= 1048576:
        return f"{kb / 1048576:.1f}G"
    return f"{kb / 1024:.1f}M"


USER_LABELS = {
    "arthur": "arthur", "carmack": "carmack", "derp": "derp",
    "sonsini": "sonsini", "spin": "spin", "tetra": "tetra", "yass": "yass",
}
TMUX_USERS = list(USER_LABELS.keys())


def get_tmux_map():
    """Return {pane_pid: (user_label, session_name)} across all users via sudo."""
    result = {}
    for user in TMUX_USERS:
        label = USER_LABELS[user]
        try:
            out = subprocess.check_output(
                ["sudo", "-u", user, "tmux", "list-panes", "-a",
                 "-F", "#{session_name}:#{pane_pid}"],
                stderr=subprocess.DEVNULL,
                text=True,
                timeout=3,
            )
            for line in out.strip().splitlines():
                name, _, pidstr = line.rpartition(":")
                if name and pidstr.isdigit():
                    result[int(pidstr)] = (label, name)
        except (FileNotFoundError, subprocess.CalledProcessError,
                subprocess.TimeoutExpired):
            continue
    return result


_PAGE_KB = os.sysconf("SC_PAGE_SIZE") // 1024

# --- Async full-proc scanner ---
_procscan_proc = None    # running Popen
_procscan_result = None  # last completed (ppid_map, proc_info)


def _kick_procscan():
    """Launch procscan in background if not already running."""
    global _procscan_proc
    if _procscan_proc is not None:
        return  # already running
    try:
        _procscan_proc = subprocess.Popen(
            [PROCSCAN], stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
    except (FileNotFoundError, OSError):
        pass


def _poll_procscan():
    """Check if procscan finished. If so, parse and store results, kick next."""
    global _procscan_proc, _procscan_result
    if _procscan_proc is None:
        _kick_procscan()
        return
    ret = _procscan_proc.poll()
    if ret is None:
        return  # still running
    # Done — parse output
    ppid_map = {}
    proc_info = {}
    try:
        out = _procscan_proc.stdout.read()
        for line in out.splitlines():
            parts = line.split("\t")
            if len(parts) < 6:
                continue
            pid = int(parts[0])
            comm = parts[1]
            ppid = int(parts[2])
            utime = int(parts[3])
            stime = int(parts[4])
            rss_pages = int(parts[5])
            ppid_map[pid] = ppid
            proc_info[pid] = (comm, ppid, utime, stime, rss_pages * _PAGE_KB)
    except (ValueError, IndexError, OSError):
        pass
    _procscan_proc = None
    _procscan_result = (ppid_map, proc_info)
    _kick_procscan()  # start next scan immediately


def _get_children(pid):
    """Get direct children of a PID via /proc/pid/task/pid/children."""
    try:
        with open(f"/proc/{pid}/task/{pid}/children") as f:
            return [int(x) for x in f.read().split()]
    except (FileNotFoundError, ProcessLookupError, PermissionError,
            OSError, ValueError):
        return []


def _read_stat_for_pid(pid):
    """Read stat for a single known PID. Returns (comm, ppid, utime, stime, rss_kb) or None."""
    try:
        fd = os.open(f"/proc/{pid}/stat", os.O_RDONLY)
        raw = os.read(fd, 400)
        os.close(fd)
        i = raw.rfind(b")")
        comm = raw[raw.index(b"(") + 1 : i].decode()
        fields = raw[i + 2 :].split()
        return (comm, int(fields[1]),
                int(fields[11]), int(fields[12]), int(fields[21]) * _PAGE_KB)
    except (FileNotFoundError, ProcessLookupError, ValueError, IndexError,
            PermissionError, OSError):
        return None


def build_tmux_snapshot(tmux_map):
    """Fast targeted scan: walk process tree from tmux pane PIDs only (~40 PIDs).
    Returns (ppid_map, proc_info) for tmux subtree only."""
    ppid_map = {}
    proc_info = {}
    # Walk descendants of all tmux pane pids
    queue = list(tmux_map.keys())
    visited = set()
    while queue:
        pid = queue.pop()
        if pid in visited:
            continue
        visited.add(pid)
        info = _read_stat_for_pid(pid)
        if info is None:
            continue
        comm, ppid, utime, stime, rss_kb = info
        ppid_map[pid] = ppid
        proc_info[pid] = (comm, ppid, utime, stime, rss_kb)
        queue.extend(_get_children(pid))
    return ppid_map, proc_info


def build_proc_snapshot(tmux_map):
    """Hybrid snapshot: fast tmux tree + async full scan for non-tmux procs.
    Returns (ppid_map, proc_info) merged."""
    # Always do the fast tmux tree walk (~0.01s)
    ppid_map, proc_info = build_tmux_snapshot(tmux_map)

    # Merge in last completed full scan for non-tmux procs
    _poll_procscan()
    if _procscan_result:
        full_ppid, full_info = _procscan_result
        for pid, info in full_info.items():
            if pid not in proc_info:  # tmux snapshot takes priority
                proc_info[pid] = info
        for pid, ppid in full_ppid.items():
            if pid not in ppid_map:
                ppid_map[pid] = ppid

    return ppid_map, proc_info


def find_tmux_session(pid, ppid_map, tmux_map):
    visited = set()
    cur = pid
    while cur and cur not in visited:
        if cur in tmux_map:
            return tmux_map[cur]
        visited.add(cur)
        cur = ppid_map.get(cur)
    return ("", "")


def is_claude(comm):
    return comm == "claude"


# Build UID->name cache once per refresh
def build_uid_map():
    """Return {uid: username} from /etc/passwd."""
    result = {}
    try:
        with open("/etc/passwd") as f:
            for line in f:
                parts = line.split(":")
                if len(parts) >= 3:
                    result[int(parts[2])] = parts[0]
    except OSError:
        pass
    return result


def read_proc_owner(pid, uid_map):
    """Return username for a process from /proc/PID/status."""
    try:
        with open(f"/proc/{pid}/status") as f:
            for line in f:
                if line.startswith("Uid:"):
                    uid = int(line.split()[1])
                    return uid_map.get(uid, str(uid))
    except (FileNotFoundError, ProcessLookupError, PermissionError,
            OSError, ValueError, IndexError):
        pass
    return ""


def read_proc_cwd(pid):
    """Return cwd for a process, or empty string."""
    try:
        return os.readlink(f"/proc/{pid}/cwd")
    except (FileNotFoundError, ProcessLookupError, PermissionError, OSError):
        return ""


def resolve_session_ids(claude_pids_cwds):
    """Given {pid: cwd}, return {pid: session_id} by tailing history.jsonl."""
    # Build {project: session_id} from recent history across users
    proj_to_session = {}
    for home in [f"/home/{u}" for u in USER_LABELS]:
        path = f"{home}/.claude/history.jsonl"
        try:
            out = subprocess.check_output(
                ["tail", f"-{HISTORY_TAIL_LINES}", path],
                text=True, stderr=subprocess.DEVNULL, timeout=2,
            )
        except (subprocess.CalledProcessError, FileNotFoundError,
                subprocess.TimeoutExpired):
            continue
        for line in out.strip().splitlines():
            try:
                entry = json.loads(line)
                proj = entry.get("project", "")
                sid = entry.get("sessionId", "")
                if proj and sid:
                    proj_to_session[proj] = sid
            except (json.JSONDecodeError, ValueError):
                continue
    # Match by cwd
    result = {}
    for pid, cwd in claude_pids_cwds.items():
        result[pid] = proj_to_session.get(cwd, "")
    return result


# Persistent state across ticks
_session_cache = {}   # {pid: session_id} - resolved once per PID lifetime
_known_pids = set()   # claude PIDs seen last tick
_log_fh = None


def init_logging():
    global _log_fh
    os.makedirs(LOG_DIR, exist_ok=True)
    _log_fh = open(LOG_PATH, "a")


def log_claude_tick(ts_iso, pid, cpu, rss_kb, user, tmux_sess, session_id, cwd):
    if not _log_fh:
        return
    record = {
        "ts": ts_iso, "pid": pid, "cpu": round(cpu, 1), "rss_kb": rss_kb,
        "user": user, "tmux": tmux_sess, "session_id": session_id, "cwd": cwd,
    }
    _log_fh.write(json.dumps(record, separators=(",", ":")) + "\n")


def log_event(ts_iso, pid, event, user="", tmux_sess="", session_id="", cwd=""):
    if not _log_fh:
        return
    record = {
        "ts": ts_iso, "event": event, "pid": pid,
        "user": user, "tmux": tmux_sess, "session_id": session_id, "cwd": cwd,
    }
    _log_fh.write(json.dumps(record, separators=(",", ":")) + "\n")


def flush_log():
    if _log_fh:
        _log_fh.flush()


def collect_processes(prev_cpu):
    clk = os.sysconf("SC_CLK_TCK")
    now = time.monotonic()

    tmux_map = get_tmux_map()
    ppid_map, proc_info = build_proc_snapshot(tmux_map)
    uid_map = build_uid_map()

    new_cpu = {}
    tmux_claude = []
    tmux_other = []
    free_claude = []
    free_other = []

    for pid, (comm, _ppid, utime, stime, rss) in proc_info.items():
        total = utime + stime
        new_cpu[pid] = (total, now)

        cpu_pct = 0.0
        if pid in prev_cpu:
            prev_total, prev_time = prev_cpu[pid]
            dt = now - prev_time
            if dt > 0.1:
                cpu_pct = max(0.0, ((total - prev_total) / clk) / dt * 100.0)

        tmux_user, session = find_tmux_session(pid, ppid_map, tmux_map)
        user = tmux_user if tmux_user else read_proc_owner(pid, uid_map)
        row = (pid, comm, cpu_pct, rss, user, session)

        if session:
            (tmux_claude if is_claude(comm) else tmux_other).append(row)
        else:
            (free_claude if is_claude(comm) else free_other).append(row)

    for lst in (tmux_claude, tmux_other, free_claude, free_other):
        lst.sort(key=lambda r: r[2], reverse=True)

    # === Session ID resolution and logging for claude processes ===
    global _known_pids
    all_claudes = tmux_claude + free_claude
    current_claude_pids = set()

    # Resolve session IDs for new claudes
    needs_resolve = {}
    for pid, comm, cpu, rss, user, sess in all_claudes:
        current_claude_pids.add(pid)
        if pid not in _session_cache:
            cwd = read_proc_cwd(pid)
            needs_resolve[pid] = cwd

    if needs_resolve:
        resolved = resolve_session_ids(needs_resolve)
        _session_cache.update(resolved)

    # Log ticks and events
    ts_iso = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())

    # Appear events
    for pid in current_claude_pids - _known_pids:
        cwd = read_proc_cwd(pid)
        sid = _session_cache.get(pid, "")
        # find user/tmux from the rows
        for p, c, cpu, rss, u, s in all_claudes:
            if p == pid:
                log_event(ts_iso, pid, "appear", user=u, tmux_sess=s,
                          session_id=sid, cwd=cwd)
                break

    # Disappear events
    for pid in _known_pids - current_claude_pids:
        sid = _session_cache.pop(pid, "")
        log_event(ts_iso, pid, "disappear", session_id=sid)

    _known_pids = current_claude_pids

    # Log each claude process tick
    for pid, comm, cpu, rss, user, sess in all_claudes:
        cwd = read_proc_cwd(pid)
        sid = _session_cache.get(pid, "")
        log_claude_tick(ts_iso, pid, cpu, rss, user, sess, sid, cwd)

    flush_log()

    # Filter idle shells from TMUX / OTHER
    def is_idle_shell(row):
        _, comm, cpu, rss, _, _ = row
        return comm in TMUX_SHELL_COMMS and cpu < MIN_CPU and rss < 10240
    filtered_tmux_other = [r for r in tmux_other if not is_idle_shell(r)]
    tmux_other_hidden = len(tmux_other) - len(filtered_tmux_other)

    # Filter noise from NON-TMUX / OTHER
    filtered_other = [r for r in free_other if r[2] >= MIN_CPU or r[3] >= MIN_RSS_KB]
    hidden = len(free_other) - len(filtered_other)

    sections = [
        ("TMUX / CLAUDE", tmux_claude, 0),
        ("TMUX / OTHER", filtered_tmux_other, tmux_other_hidden),
        ("NON-TMUX / CLAUDE", free_claude, 0),
        ("NON-TMUX / OTHER", filtered_other, hidden),
    ]
    return sections, new_cpu


def section_totals(rows):
    """Return (total_cpu, total_rss_kb, count)."""
    cpu = sum(r[2] for r in rows)
    rss = sum(r[3] for r in rows)
    return cpu, rss, len(rows)


def init_colors():
    curses.start_color()
    curses.use_default_colors()
    # 1: section headers (cyan)
    curses.init_pair(1, curses.COLOR_CYAN, -1)
    # 2: claude rows (green)
    curses.init_pair(2, curses.COLOR_GREEN, -1)
    # 3: high cpu (red) - >50%
    curses.init_pair(3, curses.COLOR_RED, -1)
    # 4: medium cpu (yellow) - >10%
    curses.init_pair(4, curses.COLOR_YELLOW, -1)
    # 5: totals header (magenta)
    curses.init_pair(5, curses.COLOR_MAGENTA, -1)
    # 6: dim (for hidden count)
    curses.init_pair(6, curses.COLOR_WHITE, -1)


def cpu_color(cpu_pct):
    if cpu_pct >= 50.0:
        return curses.color_pair(3) | curses.A_BOLD
    if cpu_pct >= 10.0:
        return curses.color_pair(4)
    return 0


def main(stdscr):
    curses.curs_set(0)
    init_colors()
    init_logging()
    stdscr.timeout(1500)

    prev_cpu = {}

    while True:
        t0 = time.monotonic()
        sections, prev_cpu = collect_processes(prev_cpu)
        collect_elapsed = time.monotonic() - t0
        stdscr.erase()
        height, width = stdscr.getmaxyx()
        if height < 2 or width < 20:
            stdscr.addnstr(0, 0, "terminal too small", width)
            stdscr.refresh()
            stdscr.getch()
            continue

        # Column layout: PID(7) CMD(flex) CPU%(7) RSS(8) USER(6) SESSION(rest)
        user_w = 6
        sess_w = 24
        fixed = 7 + 1 + 7 + 1 + 8 + 1 + user_w + 1 + sess_w
        cmd_w = max(8, width - fixed - 1)

        # === TOTALS HEADER ===
        ncpu = os.cpu_count() or 1
        y = 0
        grand_cpu, grand_rss = 0.0, 0
        sec_summaries = []
        for sec_name, rows, _hidden in sections:
            cpu, rss, cnt = section_totals(rows)
            grand_cpu += cpu
            grand_rss += rss
            sec_summaries.append((sec_name, cpu, rss, cnt))

        bar_w = 20
        cpu_max = ncpu * 100
        cpu_frac = min(grand_cpu / cpu_max, 1.0)
        cpu_filled = int(cpu_frac * bar_w * 8)
        cpu_full = cpu_filled // 8
        cpu_part = cpu_filled % 8
        blocks = "\u2588" * cpu_full
        if cpu_part and cpu_full < bar_w:
            blocks += chr(0x2590 - cpu_part)
        cpu_bar = blocks.ljust(bar_w)

        total_mem_kb = os.sysconf("SC_PHYS_PAGES") * os.sysconf("SC_PAGE_SIZE") // 1024
        # Use /proc/meminfo for actual used memory (no shared page double-counting)
        used_mem_kb = total_mem_kb
        try:
            with open("/proc/meminfo") as f:
                mi = {}
                for line in f:
                    parts = line.split()
                    if len(parts) >= 2:
                        mi[parts[0].rstrip(":")] = int(parts[1])
                avail = mi.get("MemAvailable", mi.get("MemFree", 0))
                used_mem_kb = total_mem_kb - avail
        except (OSError, ValueError):
            pass
        mem_frac = min(used_mem_kb / total_mem_kb, 1.0) if total_mem_kb else 0
        mem_filled = int(mem_frac * bar_w * 8)
        mem_full = mem_filled // 8
        mem_part = mem_filled % 8
        mblocks = "\u2588" * mem_full
        if mem_part and mem_full < bar_w:
            mblocks += chr(0x2590 - mem_part)
        mem_bar = mblocks.ljust(bar_w)

        title = f" claudetop | {ncpu} cores | {fmt_mem(total_mem_kb)} RAM"
        try:
            stdscr.addnstr(y, 0, title.ljust(width), width,
                           curses.A_REVERSE | curses.A_BOLD)
        except curses.error:
            pass
        y += 1

        cpu_line = f"  CPU [{cpu_bar}] {grand_cpu:6.1f}% / {cpu_max}%"
        mem_line = f"  MEM [{mem_bar}] {fmt_mem(used_mem_kb)} / {fmt_mem(total_mem_kb)}"
        for ln in (cpu_line, mem_line):
            if y >= height:
                break
            try:
                stdscr.addnstr(y, 0, ln, width,
                               curses.color_pair(5) | curses.A_BOLD)
            except curses.error:
                pass
            y += 1

        # compact per-section summary on two lines
        s = sec_summaries
        line1 = (f"  tmux/claude: {s[0][3]:>3} procs {s[0][1]:6.1f}% {fmt_mem(s[0][2]):>7}"
                 f"   tmux/other: {s[1][3]:>3} procs {s[1][1]:6.1f}% {fmt_mem(s[1][2]):>7}")
        line2 = (f"  free/claude: {s[2][3]:>3} procs {s[2][1]:6.1f}% {fmt_mem(s[2][2]):>7}"
                 f"   free/other: {s[3][3]:>3} procs {s[3][1]:6.1f}% {fmt_mem(s[3][2]):>7}")
        for ln in (line1, line2):
            if y >= height:
                break
            try:
                stdscr.addnstr(y, 0, ln, width, curses.color_pair(5))
            except curses.error:
                pass
            y += 1

        # color legend
        if y < height:
            legend_parts = [
                ("  ", 0),
                ("\u2588 >50% ", curses.color_pair(3) | curses.A_BOLD),
                ("\u2588 >10% ", curses.color_pair(4)),
                ("\u2588 claude ", curses.color_pair(2)),
                ("\u2588 other", 0),
            ]
            x = 0
            for text, attr in legend_parts:
                if x + len(text) > width:
                    break
                try:
                    stdscr.addnstr(y, x, text, width - x, attr)
                except curses.error:
                    pass
                x += len(text)
            y += 1

        # blank separator
        y += 1

        # === SECTIONS ===
        for sec_name, rows, hidden in sections:
            if y >= height:
                break
            # Section header with aggregate stats
            sec_cpu, sec_rss, sec_cnt = section_totals(rows)
            hdr = f"--- {sec_name} ({sec_cnt}"
            if hidden:
                hdr += f" +{hidden} idle"
            hdr += f") | {sec_cpu:5.1f}% CPU | {fmt_mem(sec_rss)} RSS "
            hdr = hdr + "-" * max(0, width - len(hdr))
            try:
                stdscr.addnstr(y, 0, hdr, width,
                               curses.color_pair(1) | curses.A_BOLD)
            except curses.error:
                pass
            y += 1

            if not rows:
                if y < height:
                    try:
                        stdscr.addnstr(y, 0, "  (none)", width, curses.A_DIM)
                    except curses.error:
                        pass
                    y += 1
                continue

            # Column header
            if y < height:
                col_hdr = (f"{'PID':>7} {'COMMAND':<{cmd_w}} "
                           f"{'CPU%':>7} {'RSS':>8} {'USER':<{user_w}} {'SESSION'}")
                try:
                    stdscr.addnstr(y, 0, col_hdr.ljust(width), width, curses.A_REVERSE)
                except curses.error:
                    pass
                y += 1

            for pid, comm, cpu, rss, user, sess in rows:
                if y >= height:
                    break
                if len(comm) > cmd_w:
                    comm = comm[: cmd_w - 1] + "~"
                line = (f"{pid:>7} {comm:<{cmd_w}} "
                        f"{cpu:>6.1f}% {fmt_mem(rss):>8} {user:<{user_w}} {sess}")
                attr = cpu_color(cpu)
                if is_claude(comm) and not attr:
                    attr = curses.color_pair(2)
                try:
                    stdscr.addnstr(y, 0, line, width, attr)
                except curses.error:
                    pass
                y += 1

        stdscr.refresh()
        # Tmux tree walk is ~0.01s. Full scan runs async in background.
        remaining = 1.5 - (time.monotonic() - t0)
        if remaining > 0.05:
            stdscr.timeout(int(remaining * 1000))
        else:
            stdscr.timeout(50)
        if stdscr.getch() in (ord("q"), ord("Q")):
            break


if __name__ == "__main__":
    curses.wrapper(main)
